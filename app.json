{
  "expo": {
    "name": "Showup",
    "slug": "showup",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "showup",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.showup.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Showup uses your microphone to have voice conversations with your coach.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "ai.showup.app",
      "adaptiveIcon": {
        "backgroundColor": "#03040A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#38BDF8",
          "androidMode": "default",
          "androidCollapsedTitle": "Showup"
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 26,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bfc668ac-0784-442b-8730-a5cfe29fe58c"
      }
    },
    "owner": "krishnateja_777"
  }
}
