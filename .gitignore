# ──────────────────────────────────────────────────────────────
# Secrets & credentials — NEVER commit these
# ──────────────────────────────────────────────────────────────
# Env files (templates like .env.example stay tracked)
.env
.env.*
!.env.example
!.env.*.example

# Private keys / certs / signing material
*.pem
*.key
*.p8
*.p12
*.keystore
*.jks
*.mobileprovision

# Provider config that carries credentials
google-service-account*.json
service-account*.json
*-service-account.json
google-services.json
GoogleService-Info.plist
**/serviceAccount*.json

# Misc secret blobs
secrets.*
*.secret
.secrets/

# Local chat transcript (contained secrets)
conversation.md

# ──────────────────────────────────────────────────────────────
# Node / Expo / React Native
# ──────────────────────────────────────────────────────────────
node_modules/
.expo/
dist/
web-build/
*.log

# Native build artifacts (generated by `expo prebuild`)
android/
ios/

# Supabase local state
supabase/.temp/
supabase/.branches/

# Scratch / throwaway
scratch/

# ──────────────────────────────────────────────────────────────
# IDE / OS noise
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

